<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Overwatch EUD (Android MVP)"
            android:textStyle="bold"
            android:textSize="20sp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="Callsign"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/callsignInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="ANDROID-EUD"
            android:text="ANDROID-EUD" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="Hub URL"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/hubUrlInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="http://192.168.1.143:8789"
            android:text="http://192.168.1.143:8789" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="Wi-Fi Privacy Mode"
            android:textStyle="bold" />

        <Spinner
            android:id="@+id/privacySpinner"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="PLI Source Mode"
            android:textStyle="bold" />

        <Spinner
            android:id="@+id/pliModeSpinner"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="PLI Pull (from Hub/COP)"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">
            <CheckBox
                android:id="@+id/pullEntitiesCheck"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Entities"
                android:checked="true" />
            <CheckBox
                android:id="@+id/pullHeatCheck"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Heat"
                android:checked="true" />
            <CheckBox
                android:id="@+id/pullCamsCheck"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Cams" />
            <CheckBox
                android:id="@+id/pullSatCheck"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Sat" />
        </LinearLayout>

        <Button
            android:id="@+id/saveConfigBtn"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Save Config" />

        <Button
            android:id="@+id/startCollectorBtn"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Start Collector (Stub)" />

        <Button
            android:id="@+id/openMapBtn"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Open Tactical Map (Stub)" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="Messaging"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/msgTargetInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Target device_id (or group:group-id)" />

        <EditText
            android:id="@+id/msgBodyInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:hint="Message body" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="6dp">
            <Button
                android:id="@+id/sendMsgBtn"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Send" />
            <Button
                android:id="@+id/pollInboxBtn"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Poll Inbox" />
        </LinearLayout>

        <EditText
            android:id="@+id/groupIdInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:hint="Group ID" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="6dp">
            <Button
                android:id="@+id/createGroupBtn"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Create Group" />
            <Button
                android:id="@+id/joinGroupBtn"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Join Group" />
        </LinearLayout>

        <TextView
            android:id="@+id/msgLogText"
            android:layout_width="match_parent"
            android:layout_height="140dp"
            android:background="#0D1220"
            android:padding="8dp"
            android:text=""
            android:textColor="#C4F1FF"
            android:textSize="12sp"
            android:typeface="monospace" />

        <TextView
            android:id="@+id/statusText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="Ready"
            android:textColor="#00897B" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="Debug Log"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/debugLogText"
            android:layout_width="match_parent"
            android:layout_height="200dp"
            android:background="#111111"
            android:padding="8dp"
            android:text=""
            android:textColor="#6EE7FF"
            android:textSize="12sp"
            android:typeface="monospace" />

    </LinearLayout>

</ScrollView>
