ACLED_USERNAME=you@example.com
ACLED_PASSWORD=your_password
# Optional: preseed tokens instead of password login
# ACLED_ACCESS_TOKEN=
# ACLED_REFRESH_TOKEN=
# DB_PATH defaults to ~/.config/overwatch/conflict_events.db (persists across updates)
# Override with ./conflict_events.db for bundle-local database (will reset on rebuild)
CACHE_TTL_SECONDS=300
ACLED_AUTO_INGEST=true
ACLED_AUTO_INGEST_INTERVAL_MIN=30
ACLED_AUTO_INGEST_DAYS=7

SHODAN_API_KEY=
SHODAN_ENABLE_SCHEDULER=true
SHODAN_DISCOVERY_INTERVAL_SEC=43200
SHODAN_REGION_TTL_SEC=43200
SHODAN_DEFAULT_LIMIT=100
SHODAN_MAX_RESULTS_PER_QUERY=200
SHODAN_MAX_VISIBLE_RESULTS=2000
SHODAN_DISCOVERY_CATEGORIES=sdr,adsb_receiver,satcom,camera
SHODAN_DEFAULT_REGION_KEY=US-TX-NORTH
SHODAN_DEFAULT_REGION_QUERY=geo:33.1500,-96.9000,220
SHODAN_ENABLE_MANUAL_REFRESH=true
SHODAN_ENABLE_BUDGET_ENFORCEMENT=true

# Shodan credit-aware budget (credit-consuming queries only)
# Daily limit disabled by default (use monthly quota only)
SHODAN_MAX_CREDIT_EVENTS_PER_DAY=99999
SHODAN_MAX_CREDIT_EVENTS_PER_MONTH=100

# OSINT Events (RSS/GDELT)
ENABLE_RSS_INGEST=false
ENABLE_GDELT_INGEST=false
ENABLE_EVENT_ENRICHMENT=false
ENABLE_EVENT_SCHEDULER=false
RSS_FEED_LIST=https://feeds.bbci.co.uk/news/world/rss.xml;https://rss.nytimes.com/services/xml/rss/nyt/World.xml
RSS_POLL_INTERVAL_SEC=900
GDELT_POLL_INTERVAL_SEC=1800
GDELT_RESULT_LIMIT=100
EVENT_DEFAULT_LIMIT=200
EVENT_MIN_CONFIDENCE=0.5
