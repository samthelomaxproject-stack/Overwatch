ACLED_USERNAME=you@example.com
ACLED_PASSWORD=your_password
# Optional: preseed tokens instead of password login
# ACLED_ACCESS_TOKEN=
# ACLED_REFRESH_TOKEN=
DB_PATH=./conflict_events.db
CACHE_TTL_SECONDS=300
ACLED_AUTO_INGEST=true
ACLED_AUTO_INGEST_INTERVAL_MIN=30
ACLED_AUTO_INGEST_DAYS=7

SHODAN_API_KEY=
SHODAN_ENABLE_SCHEDULER=true
SHODAN_DISCOVERY_INTERVAL_SEC=43200
SHODAN_REGION_TTL_SEC=43200
SHODAN_DEFAULT_LIMIT=100
SHODAN_MAX_RESULTS_PER_QUERY=200
SHODAN_MAX_VISIBLE_RESULTS=2000
SHODAN_DISCOVERY_CATEGORIES=sdr,adsb_receiver,satcom,camera
SHODAN_DEFAULT_REGION_KEY=US-TX-NORTH
SHODAN_DEFAULT_REGION_QUERY=geo:33.1500,-96.9000,220
SHODAN_ENABLE_MANUAL_REFRESH=true
SHODAN_ENABLE_BUDGET_ENFORCEMENT=true
SHODAN_MAX_QUERY_CREDITS_PER_DAY=3
SHODAN_MAX_QUERY_CREDITS_PER_MONTH=90
SHODAN_QUERY_COST_ESTIMATE=1