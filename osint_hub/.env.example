ACLED_USERNAME=you@example.com
ACLED_PASSWORD=your_password
# Optional: preseed tokens instead of password login
# ACLED_ACCESS_TOKEN=
# ACLED_REFRESH_TOKEN=
DB_PATH=./conflict_events.db
CACHE_TTL_SECONDS=300
ACLED_AUTO_INGEST=true
ACLED_AUTO_INGEST_INTERVAL_MIN=30
ACLED_AUTO_INGEST_DAYS=7

SHODAN_API_KEY=
SHODAN_ENABLE_SCHEDULER=false
SHODAN_DISCOVERY_INTERVAL_SEC=900
SHODAN_REGION_TTL_SEC=900
SHODAN_CACHE_TTL_SEC=300
SHODAN_DEFAULT_LIMIT=600
SHODAN_MAX_RESULTS_PER_QUERY=50
SHODAN_MAX_VISIBLE_RESULTS=1500
SHODAN_DISCOVERY_CATEGORIES=sdr,adsb_receiver,satcom,camera
SHODAN_DEFAULT_REGION_MODE=bbox
SHODAN_ENABLE_MANUAL_REFRESH=true