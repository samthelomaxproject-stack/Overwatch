{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Overwatch",
  "version": "0.2.0",
  "identifier": "com.overwatch.toc",
  "build": {
    "frontendDist": "../webui",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "echo 'Using frontend src'",
    "beforeBuildCommand": "echo 'Building frontend'"
  },
  "app": {
    "windows": [
      {
        "title": "Overwatch",
        "width": 800,
        "height": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    },
    "withGlobalTauri": true
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.png"
    ],
    "resources": [
      "../webui/*"
    ],
    "macOS": {
      "frameworks": ["/System/Library/Frameworks/CoreLocation.framework"],
      "minimumSystemVersion": "12.0",
      "entitlements": "./Entitlements.plist",
      "infoPlist": "./Info.plist"
    }
  }
}
